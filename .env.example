# Modèle de configuration — copier vers .env et remplir.
# Le vrai .env n'est JAMAIS commité (cf. .gitignore).

# Clé API Anthropic dédiée à SynthesIA (générée sur platform.claude.com/settings/keys)
ANTHROPIC_API_KEY=sk-ant-...

# --- Envoi du brief par email (optionnel) ---
# Laisser vide pour désactiver l'envoi (le pipeline l'ignore alors).
# Le mot de passe est un « mot de passe d'application » Gmail (16 caractères),
# créé sur https://myaccount.google.com/apppasswords (2FA requise).
EMAIL_EXPEDITEUR=ton.adresse@gmail.com
EMAIL_MOT_DE_PASSE=xxxx xxxx xxxx xxxx
# Un ou plusieurs destinataires, séparés par des virgules (défaut = expéditeur) :
EMAIL_DESTINATAIRE=chef1@exemple.fr, chef2@exemple.fr
